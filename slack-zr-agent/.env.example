# Slack (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Only this Slack user can approve ZipRecruiter login (find via Slack profile → ⋮ → Copy member ID)
ALLOWED_SLACK_USER_ID=U0123456789

# Optional: Slack channel or DM user ID to send scheduled prompts (defaults to ALLOWED_SLACK_USER_ID)
SLACK_NOTIFY_USER_ID=

# Daily prompt hour in 24h format (server local time). Set SCHEDULE_ENABLED=false to disable.
SCHEDULE_ENABLED=true
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# ZipRecruiter
ZIPRECRUITER_BASE_URL=https://www.ziprecruiter.com
ZIPRECRUITER_RDB_URL=https://www.ziprecruiter.com/emp/rdb/dashboard/active_projects

# Playwright browser profile (cookies persist between runs)
BROWSER_DATA_DIR=./browser-data
PLAYWRIGHT_HEADLESS=true

# Use installed Google Chrome instead of bundled Chromium (helps avoid bot detection)
PLAYWRIGHT_CHANNEL=chrome

# Optional: connect to a Chrome window you opened manually (best if Cloudflare blocks login.py)
# Start Chrome with: /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222 --user-data-dir="./browser-data"
# CHROME_CDP_URL=http://localhost:9222

# Local folder for CSV + resume exports (created automatically)
EXPORT_BASE_DIR=./exports

# accord-headhunter integration (post-export import + Slack review prompt)
# Repo root (parent of slack-zr-agent/) — default when both live in AG_headhunter
ACCORD_HEADHUNTER_DIR=..
STREAMLIT_APP_URL=https://accord-headhunter.streamlit.app

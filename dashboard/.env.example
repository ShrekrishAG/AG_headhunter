# Accord Group — accord-headhunter Supabase project
# Create a new Supabase project and paste credentials here.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# Base project URL only — do NOT include /rest/v1/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resume pre-screen + Pipeline Redraft (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional — use different models per task:
# OPENAI_PRESCREEN_MODEL=gpt-4o-mini
# OPENAI_DRAFT_MODEL=gpt-4o-mini
# REDRAFT_MODE=template | openai | auto (template when OpenAI unavailable)
REDRAFT_MODE=template

# Round 1 invites — see integrations/*.md
# OUTBOUND_SENDS_ENABLED=false disables Send SMS / Send email on Pipeline (drafts still work)
OUTBOUND_SENDS_ENABLED=false
CALENDLY_R1_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Accord Group Recruiting

# Deployed dashboard URL (for shareable page links + Slack export notifications)
STREAMLIT_APP_URL=https://accord-recruiting.streamlit.app

# Set false to skip auto-generating reference outreach drafts after sync
GENERATE_OUTREACH_DRAFTS=true

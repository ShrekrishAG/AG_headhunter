# Accord Group — accord-headhunter Supabase project
# Create a new Supabase project and paste credentials here.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# Base project URL only — do NOT include /rest/v1/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resume pre-screen + Pipeline Redraft (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional — use different models per task:
# OPENAI_PRESCREEN_MODEL=gpt-4o-mini
# OPENAI_DRAFT_MODEL=gpt-4o-mini
# REDRAFT_MODE=template | openai | auto (template when OpenAI unavailable)
REDRAFT_MODE=template

# Round 1 invites — see integrations/*.md
# OUTBOUND_SENDS_ENABLED=false disables Send SMS / Send email on Pipeline (drafts still work)
OUTBOUND_SENDS_ENABLED=false
CALENDLY_R1_URL=

# Heymarket SMS (Settings → Integrations → API at app.heymarket.com/admin/integrations/api)
# Use API Secret (recommended) OR legacy team API key — not both required.
HEYMARKET_API_SECRET_ID=          # From "Create API Secret" → Secret ID (JWT iss)
HEYMARKET_API_SECRET_KEY=         # Shown once when secret is created — copy immediately
# HEYMARKET_API_KEY=              # Legacy: team API key from same page (simpler for testing)
HEYMARKET_INBOX_ID=               # GET /v1/inboxes → id of your recruiting inbox
HEYMARKET_CREATOR_ID=             # GET /v1/team → your member id (must be in that inbox's members)

# Twilio SMS (optional — replace with Heymarket above)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Accord Group Recruiting
# BCC on live manager packet sends (so recruiting gets a copy of each GM zip)
MANAGER_PACKET_COPY_EMAIL=shreya@dollfamilyoffice.com

# Deployed dashboard URL (for shareable page links + Slack export notifications)
STREAMLIT_APP_URL=https://accord-headhunter.streamlit.app

# Set false to skip auto-generating reference outreach drafts after sync
GENERATE_OUTREACH_DRAFTS=true
